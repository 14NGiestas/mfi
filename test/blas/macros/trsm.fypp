#:def trsm(f77,f90,mfi,pfxs,suffix='')
#:set wp = pfxs[0]
subroutine test_${f77 + suffix}$
    use f77_blas, only: ${f77}$, ${f90}$
    use mfi_blas, only: ${mfi}$, mfi_force_gpu, mfi_force_cpu

    integer, parameter :: wp = ${kind(wp)}$
    integer :: M, N
    ${type(wp)}$, allocatable :: A(:,:), B(:,:), B_in(:,:), B_rf(:,:)
    ${type(wp)}$ :: alpha
    character :: side, uplo, transa, diag
    integer :: i_side, i_uplo, i_transa, i_diag
    integer :: ir, ic

    character, parameter :: sides(*) = ['L', 'R']
    character, parameter :: uplos(*) = ['U', 'L']
    character, parameter :: transas(*) = ['N', 'T', 'C']
    character, parameter :: diags(*) = ['N', 'U']

    $:test_seed()
    call test_get_2d(2000, M)
    N = M

    allocate(A(M,M), B(M,N), B_in(M,N), B_rf(M,N))
    ! Generate a well-conditioned triangular matrix
    $:random_number(type(wp),'A','(M,M)')
    $:random_number(type(wp),'B','(M,N)')
    $:random_number(type(wp),'alpha')
    ! Zero out half, scale off-diagonal, set diagonal to [1,2]
    do ir = 1, M
        do ic = 1, M
            if (ic > ir) then
                A(ir, ic) = 0.0_wp
            else if (ic == ir) then
                A(ir, ic) = 1.0_wp + real(ir, wp) * 0.1_wp
            else
                A(ir, ic) = (A(ir, ic) - 0.5_wp) * 0.2_wp
            end if
        end do
    end do

    do i_side = 1, size(sides)
    do i_uplo = 1, size(uplos)
    do i_transa = 1, size(transas)
    do i_diag = 1, size(diags)
        side   = sides(i_side)
        uplo   = uplos(i_uplo)
        transa = transas(i_transa)
        diag   = diags(i_diag)

        B_rf = B
        call ${f77}$(side, uplo, transa, diag, M, N, alpha, A, M, B_rf, M)

        B_in = B
        call ${mfi}$(A, B_in, side=side, uplo=uplo, transa=transa, diag=diag, alpha=alpha)
        @:assert_close(B_in, B_rf, '${mfi}$:' // side // uplo // transa // diag, ${wp}$)

#if defined(MFI_CUBLAS)
        call mfi_force_gpu()
        B_in = B
        call ${mfi}$(A, B_in, side=side, uplo=uplo, transa=transa, diag=diag, alpha=alpha)
        call mfi_force_cpu()
        @:assert_close(B_in, B_rf, 'GPU:${mfi}$:' // side // uplo // transa // diag, ${wp}$)
#endif

    end do
    end do
    end do
    end do
    deallocate(A, B, B_in, B_rf)
end subroutine
#:enddef
