#:def ung2r(f77,f90,mfi,pfxs)
#:set wp = pfxs[0]
#:set f77_gen = f77
#:set f90_gen = f90
#:set mfi_gen = mfi
#! Get the corresponding factorization routine name
#:set f77_fac = f77.replace('g2','q2').replace('g','ge')
#:set f90_fac = f90.replace('g2','q2').replace('g','ge')
subroutine test_${f77_gen + suffix}$
    use f77_lapack, only: ${f77_gen}$, ${f90_gen}$
    use mfi_blas
    use mfi_lapack, only: ${mfi_gen}$, mfi_${f77_gen}$

    integer, parameter :: wp = ${kind(wp)}$
    integer, parameter :: M = 3, N = 2
    ${type(wp)}$ :: A(M,N), A_copy(M,N), A_rf(M,N), tau(min(M,N))
    ${type(wp)}$, allocatable :: work(:)
    integer :: info, info_rf, info_mfi

    ! Create a test matrix
    A(1,1) = cmplx(2.0_wp, 0.5_wp); A(1,2) = cmplx(1.0_wp, -0.3_wp)
    A(2,1) = cmplx(1.0_wp, -0.2_wp); A(2,2) = cmplx(2.0_wp, 0.1_wp)
    A(3,1) = cmplx(1.0_wp, 0.4_wp); A(3,2) = cmplx(1.0_wp, -0.1_wp)

    allocate(work(M))

    ! Reference: factorize then generate
    A_copy = A
    call ${f77_fac}$(M, N, A_copy, M, tau, info)
    A_rf = A_copy
    call ${f77_gen}$(M, N, min(M,N), A_rf, M, tau, work, info_rf)

    ! Test mfi interface
    A_copy = A
    call ${f77_fac}$(M, N, A_copy, M, tau, info)
    call mfi_${f77_gen}$(A_copy, tau, k=min(M,N), info=info_mfi)
    call assert(all(abs(A_copy - A_rf) < sqrt(epsilon(1.0_wp))), &
                "different results for mfi_${f77_gen}$")

    ! Test full mfi interface
    A_copy = A
    call ${f77_fac}$(M, N, A_copy, M, tau, info)
    call ${mfi_gen}$(A_copy, tau, k=min(M,N), info=info_mfi)
    call assert(all(abs(A_copy - A_rf) < sqrt(epsilon(1.0_wp))), &
                "different results for ${mfi_gen}$")

    deallocate(work)

end subroutine
#:enddef
